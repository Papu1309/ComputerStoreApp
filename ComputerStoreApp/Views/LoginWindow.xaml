<Window x:Class="ComputerStoreApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация - Компьютерные магазины" 
        Height="500" Width="550" 
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundColor}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryColor}" Height="100">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="🖥️ Компьютерные магазины" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Автоматизированная информационная система" 
                           FontSize="14" 
                           Foreground="#BDC3C7"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel VerticalAlignment="Center" 
                        HorizontalAlignment="Center"
                        Width="380"
                        Margin="0,30">

                <Border Background="White" 
                        CornerRadius="10" 
                        Padding="30"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Вход в систему" 
                                   FontSize="24" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource PrimaryColor}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,25"/>

                        <Label Content="Логин"/>
                        <TextBox x:Name="txtLogin" Height="45" FontSize="14"/>

                        <Label Content="Пароль" Margin="0,15,0,0"/>
                        <PasswordBox x:Name="txtPassword" Height="45" FontSize="14"/>

                        <Button x:Name="btnLogin" 
                                Content="Войти" 
                                Height="45" 
                                FontSize="16"
                                Margin="0,25,0,0"
                                Click="BtnLogin_Click"/>

                        <TextBlock x:Name="txtError" 
                                   Foreground="Red" 
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0"
                                   Visibility="Collapsed"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="10" Padding="30">
                    <StackPanel>
                        <TextBlock Text="Нет аккаунта?" 
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,10"/>
                        <Button x:Name="btnRegister" 
                                Content="Регистрация нового сотрудника" 
                                Height="40"
                                Background="{StaticResource InfoColor}"
                                Click="BtnRegister_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>