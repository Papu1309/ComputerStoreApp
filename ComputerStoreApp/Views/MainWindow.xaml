<Window x:Class="ComputerStoreApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Компьютерные магазины - Главная" 
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryColor}" Height="70">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="🖥️" FontSize="32" Foreground="White" Margin="0,0,10,0"/>
                    <TextBlock Text="Компьютерные магазины" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button x:Name="btnProducts" Content="📦 Товары" Width="120" Click="BtnProducts_Click"/>
                    <Button x:Name="btnCart" Content="🛒 Корзина" Width="120" Click="BtnCart_Click"/>
                    <Button x:Name="btnOrders" Content="📋 Мои заказы" Width="120" Click="BtnOrders_Click"/>
                    <Button x:Name="btnProfile" Content="👤 Профиль" Width="120" Click="BtnProfile_Click"/>
                    <Button x:Name="btnAdmin" Content="⚙️ Администрирование" Width="180" Visibility="Collapsed" Click="BtnAdmin_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,20,0" VerticalAlignment="Center">
                    <Border Background="#34495E" CornerRadius="5" Padding="10,5" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤 " Foreground="White"/>
                            <TextBlock x:Name="txtUserInfo" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Button x:Name="btnLogout" Content="🚪 Выход" Width="90" Background="{StaticResource AccentColor}" Click="BtnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>

        <Border Grid.Row="2" Background="#34495E" Height="35">
            <Grid>
                <TextBlock Text="© 2026 Компьютерные магазины. Все права защищены. | Версия 2.0" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                <TextBlock x:Name="txtStoreInfo" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0" FontSize="11"/>
            </Grid>
        </Border>
    </Grid>
</Window>