<Page x:Class="ComputerStoreApp.Views.Pages.CartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Корзина"
      Background="{StaticResource BackgroundColor}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="🛒 Корзина покупок" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}"/>
                <TextBlock Text="Проверьте товары и оформите заказ" FontSize="12" Foreground="Gray" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <DataGrid x:Name="dgCart" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" RowHeight="45">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Артикул" Binding="{Binding SKU}" Width="100"/>
                <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="300"/>
                <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="120"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat='{}{0:C}'}" Width="120"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding Total, StringFormat='{}{0:C}'}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource SuccessColor}"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="Действия" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="🗑 Удалить" Click="RemoveFromCart_Click" Tag="{Binding ProductId}" Background="{StaticResource AccentColor}" Height="30" Padding="10,5"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="20" Margin="0,20,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Итого к оплате:" FontSize="16" FontWeight="Bold"/>
                    <TextBlock x:Name="txtTotalAmount" FontSize="28" FontWeight="Bold" Foreground="{StaticResource SuccessColor}" Margin="0,5,0,0"/>
                    <TextBlock Text="Включая НДС 20%" FontSize="11" Foreground="Gray" Margin="0,5,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="btnClearCart" Content="🗑 Очистить корзину" Background="{StaticResource WarningColor}" Click="BtnClearCart_Click" Height="45" Width="160"/>
                    <Button x:Name="btnCheckout" Content="✅ Оформить заказ" Background="{StaticResource SuccessColor}" Click="BtnCheckout_Click" Height="45" Width="150" Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="emptyCartPanel" Grid.Row="1" Background="White" CornerRadius="10" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
            <StackPanel Margin="50" HorizontalAlignment="Center">
                <TextBlock Text="🛒" FontSize="64" HorizontalAlignment="Center"/>
                <TextBlock Text="Корзина пуста" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,20,0,10"/>
                <TextBlock Text="Добавьте товары из каталога" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>