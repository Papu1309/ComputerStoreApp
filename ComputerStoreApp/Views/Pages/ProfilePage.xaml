<Page x:Class="ComputerStoreApp.Views.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Профиль"
      Background="{StaticResource BackgroundColor}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="👤 Личный профиль" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource PrimaryColor}"/>
                    <TextBlock Text="Ваши персональные данные и статистика" 
                               FontSize="12" 
                               Foreground="Gray"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1">
                <Border Background="White" CornerRadius="10" Padding="25" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="📋 Информация о сотруднике" 
                                   FontSize="18" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryColor}"
                                   Margin="0,0,0,20"/>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="ФИО:" Grid.Row="0" Grid.Column="0" 
                                       FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtFullName" Grid.Row="0" Grid.Column="1" 
                                       FontSize="14" Margin="10,5,0,5"/>

                            <TextBlock Text="Логин:" Grid.Row="1" Grid.Column="0" 
                                       FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="0,10,0,0"/>
                            <TextBlock x:Name="txtLogin" Grid.Row="1" Grid.Column="1" 
                                       FontSize="14" Margin="10,10,0,0"/>

                            <TextBlock Text="Роль:" Grid.Row="2" Grid.Column="0" 
                                       FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="0,10,0,0"/>
                            <TextBlock x:Name="txtRole" Grid.Row="2" Grid.Column="1" 
                                       FontSize="14" Margin="10,10,0,0"/>

                            <TextBlock Text="Магазин:" Grid.Row="3" Grid.Column="0" 
                                       FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="0,10,0,0"/>
                            <TextBlock x:Name="txtStore" Grid.Row="3" Grid.Column="1" 
                                       FontSize="14" Margin="10,10,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="10" Padding="25" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="📊 Статистика продаж" 
                                   FontSize="18" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryColor}"
                                   Margin="0,0,0,20"/>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Всего продаж:" Grid.Row="0" Grid.Column="0" 
                                       FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtTotalSales" Grid.Row="0" Grid.Column="1" 
                                       FontSize="14" Margin="10,5,0,5"/>

                            <TextBlock Text="На сумму:" Grid.Row="1" Grid.Column="0" 
                                       FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="0,10,0,0"/>
                            <TextBlock x:Name="txtTotalAmount" Grid.Row="1" Grid.Column="1" 
                                       FontSize="14" Margin="10,10,0,0" Foreground="{StaticResource SuccessColor}" FontWeight="Bold"/>

                            <TextBlock Text="Средний чек:" Grid.Row="2" Grid.Column="0" 
                                       FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="0,10,0,0"/>
                            <TextBlock x:Name="txtAvgCheck" Grid.Row="2" Grid.Column="1" 
                                       FontSize="14" Margin="10,10,0,0" Foreground="{StaticResource SuccessColor}"/>

                            <TextBlock Text="Лучший день:" Grid.Row="3" Grid.Column="0" 
                                       FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="0,10,0,0"/>
                            <TextBlock x:Name="txtBestDay" Grid.Row="3" Grid.Column="1" 
                                       FontSize="14" Margin="10,10,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="10" Padding="25" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="ℹ️ Дополнительная информация" 
                                   FontSize="18" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryColor}"
                                   Margin="0,0,0,20"/>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Дата регистрации:" Grid.Row="0" Grid.Column="0" 
                                       FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtRegistrationDate" Grid.Row="0" Grid.Column="1" 
                                       FontSize="14" Margin="10,5,0,5"/>

                            <TextBlock Text="Статус:" Grid.Row="1" Grid.Column="0" 
                                       FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="0,10,0,0"/>
                            <TextBlock x:Name="txtStatus" Grid.Row="1" Grid.Column="1" 
                                       FontSize="14" Margin="10,10,0,0" Foreground="{StaticResource SuccessColor}"/>

                            <TextBlock Text="Последняя активность:" Grid.Row="2" Grid.Column="0" 
                                       FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="0,10,0,0"/>
                            <TextBlock x:Name="txtLastActivity" Grid.Row="2" Grid.Column="1" 
                                       FontSize="14" Margin="10,10,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Button x:Name="btnChangePassword" 
                        Content="🔒 Сменить пароль" 
                        Height="45"
                        Width="200"
                        HorizontalAlignment="Center"
                        Margin="0,10,0,20"
                        Background="{StaticResource WarningColor}"
                        Click="BtnChangePassword_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>