<Page x:Class="ComputerStoreApp.Views.Pages.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Мои заказы"
      Background="{StaticResource BackgroundColor}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="📋 История заказов" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource PrimaryColor}"/>
                <TextBlock Text="Все ваши покупки в одном месте" 
                           FontSize="12" 
                           Foreground="Gray"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid x:Name="ordersGrid" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="dgOrders" Grid.Row="0" 
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionChanged="DgOrders_SelectionChanged"
                          Margin="0,0,0,10"
                          Height="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="№ Заказа" Binding="{Binding SaleId}" Width="80"/>
                        <DataGridTextColumn Header="Дата" Binding="{Binding SaleDate, StringFormat='dd.MM.yyyy HH:mm'}" Width="150"/>
                        <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount, StringFormat='{}{0:C}'}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource SuccessColor}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Магазин" Binding="{Binding Stores.Name}" Width="200"/>
                        <DataGridTextColumn Header="Продавец" Binding="{Binding Employees.FullName}" Width="200"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="15" 
                        Margin="0,10,0,0" Height="220">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Состав заказа:" 
                                   FontSize="14" 
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <DataGrid x:Name="dgOrderItems" Grid.Row="1" 
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  Height="170">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Товар" Binding="{Binding Products.Name}" Width="*"/>
                                <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="*"/>
                                <DataGridTextColumn Header="Цена" Binding="{Binding SalePrice, StringFormat='{}{0:C}'}" Width="*"/>
                                <DataGridTextColumn Header="Сумма" Width="*">
                                    <DataGridTextColumn.Binding>
                                        <MultiBinding StringFormat="{}{0:C}">
                                            <Binding Path="Quantity"/>
                                            <Binding Path="SalePrice"/>
                                        </MultiBinding>
                                    </DataGridTextColumn.Binding>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <Border x:Name="emptyOrdersPanel" 
                    Background="White" 
                    CornerRadius="10" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    Visibility="Collapsed">
                <StackPanel Margin="50" HorizontalAlignment="Center">
                    <TextBlock Text="📦" FontSize="64" HorizontalAlignment="Center"/>
                    <TextBlock Text="У вас пока нет заказов" 
                               FontSize="20" 
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,20,0,10"/>
                    <TextBlock Text="Перейдите в каталог и сделайте первый заказ" 
                               FontSize="12" 
                               Foreground="Gray"
                               HorizontalAlignment="Center"/>
                    <Button Content="🛒 Перейти в каталог" 
                            Width="150" 
                            Height="35"
                            Margin="0,20,0,0"
                            Click="GoToCatalog_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>