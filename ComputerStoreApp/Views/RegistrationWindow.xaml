<Window x:Class="ComputerStoreApp.Views.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация нового сотрудника" 
        Height="650" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundColor}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource InfoColor}" Height="80">
            <TextBlock Text="Регистрация сотрудника" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Background="White" 
                    CornerRadius="10" 
                    Margin="30"
                    Padding="25">
                <StackPanel>
                    <TextBlock Text="Введите данные нового сотрудника" 
                               FontSize="16" 
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryColor}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <Label Content="ФИО *"/>
                    <TextBox x:Name="txtFullName" Height="40"/>

                    <Label Content="Логин *" Margin="0,10,0,0"/>
                    <TextBox x:Name="txtLogin" Height="40"/>

                    <Label Content="Пароль *" Margin="0,10,0,0"/>
                    <PasswordBox x:Name="txtPassword" Height="40"/>

                    <Label Content="Подтверждение пароля *" Margin="0,10,0,0"/>
                    <PasswordBox x:Name="txtConfirmPassword" Height="40"/>

                    <Label Content="Роль *" Margin="0,10,0,0"/>
                    <ComboBox x:Name="cmbRole" Height="40" SelectedIndex="0">
                        <ComboBoxItem Content="Продавец"/>
                        <ComboBoxItem Content="Старший продавец"/>
                    </ComboBox>

                    <Label Content="Магазин *" Margin="0,10,0,0"/>
                    <ComboBox x:Name="cmbStore" Height="40" 
                              DisplayMemberPath="Name" 
                              SelectedValuePath="StoreId"/>

                    <Label Content="Телефон" Margin="0,10,0,0"/>
                    <TextBox x:Name="txtPhone" Height="40"/>

                    <Button x:Name="btnRegister" 
                            Content="Зарегистрировать" 
                            Height="45" 
                            FontSize="16"
                            Margin="0,25,0,10"
                            Background="{StaticResource SuccessColor}"
                            Click="BtnRegister_Click"/>

                    <TextBlock x:Name="txtError" 
                               Foreground="Red" 
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"
                               Visibility="Collapsed"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>

                    <TextBlock Text="* - обязательные поля" 
                               FontSize="10" 
                               Foreground="Gray"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>