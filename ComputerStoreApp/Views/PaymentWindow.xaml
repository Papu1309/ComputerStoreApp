<Window x:Class="ComputerStoreApp.Views.PaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Оплата заказа" Height="650" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BackgroundColor}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource SuccessColor}" Height="100">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="💳 Оформление заказа" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Выберите способ оплаты" FontSize="12" Foreground="#E0E0E0" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Background="White" CornerRadius="10" Margin="20" Padding="20">
                <StackPanel>
                    <Border Background="#F0F0F0" CornerRadius="5" Padding="15" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Сумма к оплате:" FontSize="14" Foreground="Gray"/>
                            <TextBlock x:Name="txtTotalAmount" FontSize="32" FontWeight="Bold" Foreground="{StaticResource SuccessColor}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Способ оплаты:" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <RadioButton x:Name="rbCard" Content="💳 Банковская карта" GroupName="PaymentMethod" IsChecked="True" Margin="0,0,20,0" FontSize="14"/>
                        <RadioButton x:Name="rbCash" Content="💰 Наличные" GroupName="PaymentMethod" FontSize="14"/>
                    </StackPanel>

                    <Border x:Name="cardPanel" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Данные карты" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>
                            <Label Content="Номер карты *"/>
                            <TextBox x:Name="txtCardNumber" Height="40" MaxLength="19" TextChanged="TxtCardNumber_TextChanged"/>
                            <Grid Margin="0,15,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <Label Content="Срок действия (ММ/ГГ) *"/>
                                    <TextBox x:Name="txtExpiry" Height="40" MaxLength="5" TextChanged="TxtExpiry_TextChanged"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <Label Content="CVV/CVC *"/>
                                    <PasswordBox x:Name="txtCVV" Height="40" MaxLength="3"/>
                                </StackPanel>
                            </Grid>
                            <Label Content="Владелец карты *" Margin="0,15,0,0"/>
                            <TextBox x:Name="txtCardHolder" Height="40"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#F8F9FA" CornerRadius="5" Padding="15" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="📦 Состав заказа" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                            <ItemsControl x:Name="itemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Button x:Name="btnPay" Content="✅ Оплатить заказ" Height="50" FontSize="16" Background="{StaticResource SuccessColor}" Click="BtnPay_Click"/>
                    <TextBlock x:Name="txtError" Foreground="Red" HorizontalAlignment="Center" Margin="0,15,0,0" Visibility="Collapsed" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>