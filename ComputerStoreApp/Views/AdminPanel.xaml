<Window x:Class="ComputerStoreApp.Views.AdminPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Панель администратора" Height="700" Width="1100"
        WindowStartupLocation="CenterOwner" WindowState="Maximized">

    <Grid Background="{StaticResource BackgroundColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource PrimaryColor}" Height="60">
            <Grid>
                <TextBlock Text="⚙️ Панель администратора" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Button Content="✖ Закрыть" Width="100" HorizontalAlignment="Right" Margin="0,0,20,0" VerticalAlignment="Center" Background="{StaticResource AccentColor}" Click="BtnClose_Click"/>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="20">
            <TabItem Header="📦 Товары">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="➕ Добавить товар" Click="AddProduct_Click" Width="150"/>
                        <Button Content="✏️ Редактировать" Click="EditProduct_Click" Width="150"/>
                        <Button Content="🗑 Удалить" Click="DeleteProduct_Click" Width="120" Background="{StaticResource AccentColor}"/>
                        <Button Content="🔄 Обновить" Click="RefreshProducts_Click" Width="120"/>
                    </StackPanel>
                    <DataGrid x:Name="dgProducts" Grid.Row="1" AutoGenerateColumns="False" SelectionMode="Single" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ProductId}" Width="50"/>
                            <DataGridTextColumn Header="Артикул" Binding="{Binding SKU}" Width="100"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="250"/>
                            <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="120"/>
                            <DataGridTextColumn Header="Производитель" Binding="{Binding Manufacturer}" Width="120"/>
                            <DataGridTextColumn Header="Гарантия" Binding="{Binding WarrantyMonths}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="👥 Сотрудники">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="➕ Добавить сотрудника" Click="AddEmployee_Click" Width="180"/>
                        <Button Content="🗑 Удалить" Click="DeleteEmployee_Click" Width="100" Background="{StaticResource AccentColor}"/>
                        <Button Content="🔄 Обновить" Click="RefreshEmployees_Click" Width="120"/>
                    </StackPanel>
                    <DataGrid x:Name="dgEmployees" Grid.Row="1" AutoGenerateColumns="False" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding EmployeeId}" Width="50"/>
                            <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="200"/>
                            <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="120"/>
                            <DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="120"/>
                            <DataGridTextColumn Header="Магазин" Binding="{Binding Stores.Name}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="🏪 Магазины">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="➕ Добавить магазин" Click="AddStore_Click" Width="160"/>
                        <Button Content="✏️ Редактировать" Click="EditStore_Click" Width="140"/>
                        <Button Content="🗑 Удалить" Click="DeleteStore_Click" Width="120" Background="{StaticResource AccentColor}"/>
                        <Button Content="🔄 Обновить" Click="RefreshStores_Click" Width="120"/>
                    </StackPanel>
                    <DataGrid x:Name="dgStores" Grid.Row="1" AutoGenerateColumns="False" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding StoreId}" Width="50"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="200"/>
                            <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="250"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="📊 Отчеты">
                <TabControl Margin="10">
                    <TabItem Header="Продажи по дням">
                        <DataGrid x:Name="dgSalesByDay" AutoGenerateColumns="True" Margin="10"/>
                    </TabItem>
                    <TabItem Header="Остатки на складах">
                        <DataGrid x:Name="dgStockBalances" AutoGenerateColumns="True" Margin="10"/>
                    </TabItem>
                    <TabItem Header="Топ товаров">
                        <DataGrid x:Name="dgTopProducts" AutoGenerateColumns="True" Margin="10"/>
                    </TabItem>
                    <TabItem Header="Статистика сотрудников">
                        <DataGrid x:Name="dgEmployeeStats" AutoGenerateColumns="True" Margin="10"/>
                    </TabItem>
                </TabControl>
            </TabItem>
        </TabControl>
    </Grid>
</Window>